{
  "title": "Predictive Maintenance MLOps Dashboard",
  "uid": "predictive-maintenance",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "rate(predictive_maintenance_requests_total[1m])",
        "legendFormat": "{{endpoint}} - {{status}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Request Latency (p99)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "histogram_quantile(0.99, rate(predictive_maintenance_request_latency_seconds_bucket[5m]))",
        "legendFormat": "p99"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Anomaly Score Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "predictive_maintenance_anomaly_score",
        "legendFormat": "Anomaly Score"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Total Anomalies Detected",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "predictive_maintenance_anomalies_detected_total",
        "legendFormat": "Anomalies"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 5,
      "title": "Drift Detections by Method",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{
        "expr": "predictive_maintenance_drift_detected_total",
        "legendFormat": "{{method}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 6,
      "title": "Drift Detection Latency by Method (ms)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "expr": "rate(predictive_maintenance_drift_detection_latency_ms_sum[1m]) / rate(predictive_maintenance_drift_detection_latency_ms_count[1m])",
        "legendFormat": "{{method}}"
      }],
      "datasource": "Prometheus"
    },
    {
      "id": 7,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "expr": "rate(predictive_maintenance_requests_total{status='error'}[1m])",
        "legendFormat": "Errors/s"
      }],
      "datasource": "Prometheus"
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {}
}
